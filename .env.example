# Gedeeld wachtwoord voor toegang tot /coach
ACCESS_PASSWORD=verander-dit

# Anthropic API key (alleen server-side gebruikt)
ANTHROPIC_API_KEY=sk-ant-...

# ElevenLabs — optioneel, voor de coach die terugpraat in jouw stem.
# Zonder deze twee blijft de spraakfunctie netjes uitgeschakeld.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

